# Add Homebrew (where mise lives) and ~/.local/bin to PATH early
# so mise is findable in .zshrc, regardless of what /etc/zprofile sets up.
export PATH="/opt/homebrew/bin:$HOME/.local/bin:$PATH"

# Source machine-local overrides (not managed by chezmoi)
[ -f "$HOME/.zshenv.local" ] && . "$HOME/.zshenv.local"

# Cargo environment (if rust installed via cargo directly)
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# NVM is replaced by mise's node support
# Keeping these lines for backwards compatibility if needed
export NVM_DIR="$HOME/.config/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# antidote and fzf are now sourced in .zshrc after mise activation
# DO NOT source them here - they're installed by mise and need mise in PATH

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

