{{- /*
  Read the existing lastChangelogVersion from the live file (pi auto-bumps it
  on every CLI run). Without this, chezmoi sees drift every time pi runs. We
  preserve whatever's currently on disk and fall back to a sensible default
  on a fresh machine where the file doesn't exist yet.
*/ -}}
{{- $version := "0.70.2" -}}
{{- $settingsPath := joinPath .chezmoi.homeDir ".pi/agent/settings.json" -}}
{{- if stat $settingsPath -}}
{{-   $found := output "jq" "-r" ".lastChangelogVersion // empty" $settingsPath | trim -}}
{{-   if $found -}}
{{-     $version = $found -}}
{{-   end -}}
{{- end -}}
{
{{- if eq .profile "axon-work-computer" }}
  "defaultProvider": "anthropic",
  "defaultModel": "claude-opus-4-7",
{{- else }}
  "defaultProvider": "claude-bridge",
  "defaultModel": "claude-opus-4-7",
{{- end }}
  "defaultThinkingLevel": "high",
  "enabledModels": [
{{- if eq .profile "axon-work-computer" }}
    "openai-codex/gpt-5.4",
    "anthropic/claude-sonnet-4-6",
    "anthropic/claude-opus-4-6",
    "anthropic/claude-opus-4-7",
    "amazon-bedrock/us.anthropic.claude-sonnet-4-6",
    "amazon-bedrock/us.anthropic.claude-opus-4-6-v1",
    "amazon-bedrock/us.anthropic.claude-opus-4-7"
{{- else }}
    "openai-codex/gpt-5.4",
    "claude-bridge/claude-sonnet-4-6",
    "claude-bridge/claude-opus-4-7",
    "claude-bridge/claude-opus-4-6"
{{- end }}
  ],
  "packages": [
    "https://github.com/cartwmic/pi-rtk-optimizer",
    "npm:@marckrenn/pi-sub-bar",
    "https://github.com/cartwmic/pi-token-usage",
    "https://github.com/cartwmic/pi-mcp-adapter",
    "https://github.com/cartwmic/pi-subagents",
    "https://github.com/hk-vk/pi-connect",
    "https://github.com/ndraiman/pi-cursor-provider",
    "https://github.com/olixis/pi-openrouter-plus",
    "https://github.com/cartwmic/pi-claude-bridge",
    "git:github.com/cartwmic/pi-mobile-typing-utils"
  ],
  "compaction": {
    "enabled": false
  },
  "lastChangelogVersion": {{ $version | quote }}
}
