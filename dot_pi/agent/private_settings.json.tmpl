{{- /*
  Read the existing lastChangelogVersion from the live file (pi auto-bumps it
  on every CLI run). Without this, chezmoi sees drift every time pi runs. We
  preserve whatever's currently on disk and fall back to a sensible default
  on a fresh machine where the file doesn't exist yet.
*/ -}}
{{- $version := "0.70.2" -}}
{{- $theme := "dark" -}}
{{- $privateProvider := dict -}}
{{- if and (eq .profile "axon-work-computer") (hasKey . "privatePiProviderRef") -}}
{{-   $privateProvider = output "op" "read" .privatePiProviderRef | fromJson -}}
{{- end -}}
{{- $settingsPath := joinPath .chezmoi.homeDir ".pi/agent/settings.json" -}}
{{- if stat $settingsPath -}}
{{-   $found := output "jq" "-r" ".lastChangelogVersion // empty" $settingsPath | trim -}}
{{-   if $found -}}
{{-     $version = $found -}}
{{-   end -}}
{{-   $themeFound := output "jq" "-r" ".theme // empty" $settingsPath | trim -}}
{{-   if $themeFound -}}
{{-     $theme = $themeFound -}}
{{-   end -}}
{{- end -}}
{
{{- if eq .profile "personal" }}
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
{{- else }}
  "defaultProvider": "anthropic",
  "defaultModel": "claude-opus-4-8",
{{- end }}
  "defaultThinkingLevel": "high",
  "enabledModels": [
{{- if eq .profile "personal" }}
    "openai-codex/gpt-5.6-luna",
    "openai-codex/gpt-5.6-sol",
    "openai-codex/gpt-5.6-terra",
    "cursor/composer-2.5",
    "cursor/cursor-grok-4.5",
    "claude-bridge/claude-fable-5",
    "claude-bridge/claude-opus-4-8",
    "claude-bridge/claude-sonnet-5"
{{- else }}
    "cursor/composer-2.5",
    "cursor/cursor-grok-4.5",
    "cursor/gpt-5.6-luna",
    "cursor/gpt-5.6-terra",
    "cursor/gpt-5.6-sol",
    "anthropic/claude-fable-5",
    "anthropic/claude-opus-4-8",
    "anthropic/claude-sonnet-5"
{{- range $model := $privateProvider.models }},
    {{ printf "private-anthropic/%s" $model.id | quote }}
{{- end }}
{{- end }}
  ],
  "packages": [
    "https://github.com/cartwmic/pi-rtk-optimizer",
    "npm:@marckrenn/pi-sub-bar",
    "https://github.com/cartwmic/pi-token-usage",
    "https://github.com/cartwmic/pi-mcp-adapter",
    "https://github.com/cartwmic/pi-subagents",
    "https://github.com/hk-vk/pi-connect",
    "https://github.com/cartwmic/pi-cursor-provider",
{{- if eq .profile "personal" }}
    "https://github.com/olixis/pi-openrouter-plus",
    "https://github.com/cartwmic/pi-claude-bridge",
{{- end }}
    "https://github.com/cartwmic/pi-session-search",
    "npm:@juicesharp/rpiv-ask-user-question"
  ],
  "compaction": {
    "enabled": false
  },
  "lastChangelogVersion": {{ $version | quote }},
  "theme": {{ $theme | quote }}
}
