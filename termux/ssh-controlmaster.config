# ssh-controlmaster.config — phone-side ~/.ssh/config snippet for ntfy-harpoon-jump.
#
# NOT chezmoi-deployed (Constitution VII: Termux config never ships as dot_termux/).
# It is staged here and delivered to the phone by `termux/sync.sh` (adb push +
# marker-guarded append into the phone ~/.ssh/config). Managed block below is
# fenced by the sentinel markers so re-runs stay idempotent (Constitution IV).
#
# Purpose: make the persistent interactive `ssh -> remote zellij` Termux session
# the ControlMaster connection, so a tap-time side-channel `ssh remote 'zellij
# pipe --name jump_pane ...'` multiplexes over the LIVE connection instead of a
# fresh authenticated login.
#
# `remote` is a host ALIAS only — the real HostName/User/IdentityFile live in the
# phone's own ~/.ssh/config (reference storage location only; no secrets here).

# >>> ntfy-harpoon-jump controlmaster >>>
Host remote
    ControlMaster auto
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlPersist 10m
# <<< ntfy-harpoon-jump controlmaster <<<
