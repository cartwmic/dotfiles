#!/usr/bin/env bash
# opsx — unified multitool for the opsx-superpowers workflow.
#
#   opsx gate     <change> [--worktree <path>]    deterministic exit-code gate
#   opsx models   <role|set|get|list> ...         role->model resolver + writer
#   opsx loop     <change> [--worktree <path>]    Ralph-style fallback driver
#   opsx worktree ensure <change> [...]           deterministic worktree lifecycle
#   opsx worktree path <change>                   read-only convention-path emit
#   opsx clean    <change> [--force]              remove an abandoned change's worktree+branch
#
# Hard cutover: replaces the standalone opsx-gate / opsx-models / opsx-loop
# executables. Each subcommand body runs in a subshell function so `exit`,
# `set`, globals, and PROG stay isolated per subcommand.
# Capabilities: opsx-cli, opsx-gate-enforcement, opsx-model-config,
#               opsx-loop, opsx-loop.
set -uo pipefail

opsx_usage() {
  cat >&2 <<'USAGE'
usage: opsx <subcommand> [args]
  gate     <change> [--worktree <path>]   run the deterministic gate
  gate     <change> --cheap                deterministic checks only (no validations)
  models   <role> [--json] [--change <c>] [--with-default]   resolve a role
  models   set <role> <value> [--layer user]                 write config
  models   get <role> [--layer user]                         read config
  models   list                                              list resolved roles
  status                                  read-only fleet view (all changes)
  sweep    <change> [--worktree <path>]   migration-completeness sweep (sweep.txt)
  archive-check <change>                  land-base + ADR-dup + multi-dir advisory
  loop     <change> [--worktree <path>]   Ralph-style fallback driver
  worktree ensure <change> [--path <p>] [--integration-branch <b>]
                                          create/reuse the opsx/<change> worktree
  worktree path <change>                  print the canonical worktree path (read-only)
  clean    <change> [--force]             remove an abandoned change's worktree+branch
USAGE
}

# ============================================================================
# SUBCOMMAND: models — harness-neutral role->model resolver + write surface.
# Roles: author | review | impl | author-in-session.  Verbs: set | get | list.
# Layered resolution (read): env > change review.md front-matter >
# user ~/.config/opsx/models.yaml > built-in default. The project-layer
# openspec/opsx-models.yaml is RETIRED (design D7): it is ignored with a
# one-time stderr warning; pin per-project via change front-matter instead.
# Spec: opsx-model-config.*, opsx-cli.model-config-write-surface
# ============================================================================
opsx_models() (
	set -uo pipefail
	PROG="opsx models"
	err() { echo "$PROG: $*" >&2; }

	# --- first arg: reserved verb (shadows role position) or role ----------
	FIRST="${1:-}"
	MODE=role
	case "$FIRST" in
		set|get|list) MODE=verb; VERB="$FIRST"; shift ;;
		author|review|impl|author-in-session) MODE=role ;;
		"") err "missing role (author|review|impl|author-in-session) or verb (set|get|list)"; exit 2 ;;
		*) err "unknown role/verb: $FIRST (roles: author|review|impl|author-in-session; verbs: set|get|list)"; exit 2 ;;
	esac

	CHANGE=""; JSON=0; WITH_DEFAULT=0; LAYER=""
	if [ "$MODE" = role ]; then
		ROLE="$1"; shift
		while [ $# -gt 0 ]; do
			case "$1" in
				--change) { [ $# -ge 2 ] && [ -n "$2" ]; } || { err "--change requires a value"; exit 2; }; CHANGE="$2"; shift 2 ;;
				--change=*) CHANGE="${1#*=}"; shift ;;
				--json) JSON=1; shift ;;
				--with-default) WITH_DEFAULT=1; shift ;;
				*) err "unknown argument: $1"; exit 2 ;;
			esac
		done
	else
		POS=()
		while [ $# -gt 0 ]; do
			case "$1" in
				--layer) { [ $# -ge 2 ] && [ -n "$2" ]; } || { err "--layer requires a value"; exit 2; }; LAYER="$2"; shift 2 ;;
				--layer=*) LAYER="${1#*=}"; shift ;;
				--change) { [ $# -ge 2 ] && [ -n "$2" ]; } || { err "--change requires a value"; exit 2; }; CHANGE="$2"; shift 2 ;;
				--json) JSON=1; shift ;;
				--*) err "unknown option: $1"; exit 2 ;;
				*) POS+=("$1"); shift ;;
			esac
		done
		if [ -n "$LAYER" ]; then
			case "$LAYER" in
				user) ;;
				project) err "project model layer removed; use review.md front-matter (per-change model pinning); no file written"; exit 2 ;;
				*) err "invalid layer: $LAYER (expected user)"; exit 2 ;;
			esac
		fi
	fi

	# --- project root discovery -------------------------------------------
	ROOT=""
	if [ -n "${OPSX_ROOT:-}" ]; then
		[ -d "$OPSX_ROOT/openspec" ] || { err "OPSX_ROOT has no openspec/: $OPSX_ROOT"; exit 2; }
		ROOT="$OPSX_ROOT"
	else
		d="$(pwd)"
		while [ "$d" != "/" ]; do
			[ -d "$d/openspec" ] && { ROOT="$d"; break; }
			d="$(dirname "$d")"
		done
	fi
	USER_CFG="${OPSX_MODELS_USER_CONFIG:-$HOME/.config/opsx/models.yaml}"
	PROJECT_CFG=""
	[ -n "$ROOT" ] && PROJECT_CFG="$ROOT/openspec/opsx-models.yaml"
	# Project-layer removal (design D7): a lingering project yaml no longer
	# participates in resolution. Surface EXACTLY ONE stderr warning per
	# top-level invocation (the sentinel dedupes nested/recursive calls and the
	# subprocess fan-out in `list`); stdout contract + exit codes are unchanged.
	if [ -n "$PROJECT_CFG" ] && [ -f "$PROJECT_CFG" ] && [ -z "${OPSX_MODELS_LAYER_WARNED:-}" ]; then
		echo "$PROG: project model layer removed; use review.md front-matter (ignoring $PROJECT_CFG)" >&2
		export OPSX_MODELS_LAYER_WARNED=1
	fi

	HAVE_YQ=0; command -v yq >/dev/null 2>&1 && HAVE_YQ=1
	yq_warned=0
	need_yq() {
		if [ "$HAVE_YQ" -eq 0 ]; then
			[ "$yq_warned" -eq 0 ] && { err "yq not found; YAML file/front-matter layers skipped (env layer still honored)"; yq_warned=1; }
			return 1
		fi
		return 0
	}
	extract_fm() {
		awk 'NR==1 && $0!="---"{exit} /^---[[:space:]]*$/{c++; if(c==1) next; if(c==2) exit} c==1{print}' "$1"
	}
	yq_type()   { yq -r ".${2} | type" "$1" 2>/dev/null; }
	yq_scalar() {
		[ "$(yq_type "$1" "$2")" = "!!null" ] && return
		yq -r ".${2}" "$1" 2>/dev/null
	}
	yq_list() {
		case "$(yq_type "$1" "$2")" in
			"!!null") return ;;
			"!!seq") yq -r ".${2}[]" "$1" 2>/dev/null ;;
			*) yq -r ".${2}" "$1" 2>/dev/null ;;
		esac
	}

	# --- map a role token to its YAML key (author-in-session -> underscore) -
	yaml_key_for() {
		case "$1" in
			author-in-session) echo author_in_session ;;
			*) echo "$1" ;;
		esac
	}
	# --- resolve the file path for an explicit layer -----------------------
	layer_file() { # $1 = user|project ; echoes path or empty(project w/o root)
		case "$1" in
			user) echo "$USER_CFG" ;;
			project) echo "${PROJECT_CFG}" ;;
		esac
	}

	# ======================================================================
	# WRITE SURFACE: set / get / list
	# ======================================================================
	if [ "$MODE" = verb ]; then
		need_yq || { err "yq is required for the model write surface"; exit 2; }
		case "$VERB" in
			list)
				for r in author review impl author-in-session; do
					out="$(opsx_models "$r" --json ${CHANGE:+--change "$CHANGE"} 2>/dev/null)"
					val="$(printf '%s' "$out" | jq -r 'if (.value|type)=="array" then (.value|join(", ")) elif .value==null then "(unset)" else (.value|tostring) end' 2>/dev/null)"
					src="$(printf '%s' "$out" | jq -r '.source' 2>/dev/null)"
					printf '%-18s %s (%s)\n' "$r:" "${val:-(unset)}" "${src:-unset}"
				done
				exit 0
				;;
			get)
				grole="${POS[0]:-}"
				case "$grole" in
					author|review|impl|author-in-session) ;;
					"") err "usage: opsx models get <role> [--layer user]"; exit 2 ;;
					*) err "unknown role: $grole"; exit 2 ;;
				esac
				if [ -z "$LAYER" ]; then
					# effective resolution = the role-read path
					rargs=("$grole")
					[ "$JSON" -eq 1 ] && rargs+=(--json)
					[ -n "$CHANGE" ] && rargs+=(--change "$CHANGE")
					opsx_models "${rargs[@]}"
					exit $?
				fi
				f="$(layer_file "$LAYER")"
				[ -n "$f" ] || { err "project layer: no openspec/ root found"; exit 2; }
				[ -f "$f" ] || exit 0
				k="$(yaml_key_for "$grole")"
				if [ "$grole" = review ]; then yq_list "$f" "$k"; else yq_scalar "$f" "$k"; fi
				exit 0
				;;
			set)
				srole="${POS[0]:-}"; sval="${POS[1]:-}"
				case "$srole" in
					author|review|impl|author-in-session) ;;
					"") err "usage: opsx models set <role> <value> [--layer user]"; exit 2 ;;
					*) err "unknown role: $srole (author|review|impl|author-in-session)"; exit 2 ;;
				esac
				[ -n "$sval" ] || { err "usage: opsx models set <role> <value> [--layer user]"; exit 2 ; }
				if [ "$srole" = author-in-session ]; then
					case "$(printf '%s' "$sval" | tr 'A-Z' 'a-z')" in
						true|false) sval="$(printf '%s' "$sval" | tr 'A-Z' 'a-z')" ;;
						*) err "author-in-session must be true or false (got: $sval)"; exit 2 ;;
					esac
				fi
				tgt_layer="${LAYER:-user}"
				f="$(layer_file "$tgt_layer")"
				[ -n "$f" ] || { err "project layer: no openspec/ root found (set \$OPSX_ROOT or run inside a repo with openspec/)"; exit 2; }
				# warn on review list replacement
				if [ "$srole" = review ] && [ -f "$f" ]; then
					prior="$(yq_list "$f" review 2>/dev/null | paste -sd, - 2>/dev/null)"
					if [ -n "$prior" ] && printf '%s' "$prior" | grep -q ','; then
						err "warning: replacing the entire review list (was: $prior) with a single model; edit YAML directly for a multi-model list"
					fi
				fi
				mkdir -p "$(dirname "$f")" || { err "cannot create dir for $f"; exit 1; }
				k="$(yaml_key_for "$srole")"
				# Operate ONLY on a temp in the target dir; the final path is created/
				# replaced solely by the atomic mv AFTER yq succeeds. A failure (incl. an
				# absent target) leaves the final path exactly as it was (absent stays absent).
				tmp="$(mktemp "$(dirname "$f")/.opsx-cfg.XXXXXX")" || { err "mktemp failed"; exit 1; }
				if [ -f "$f" ]; then cp "$f" "$tmp" || { err "copy failed; $f unchanged"; rm -f "$tmp"; exit 1; }; fi
				if [ "$srole" = author-in-session ]; then
					VAL="$sval" yq -i ".${k} = (strenv(VAL) == \"true\")" "$tmp" 2>/dev/null
				else
					VAL="$sval" yq -i ".${k} = strenv(VAL)" "$tmp" 2>/dev/null
				fi
				if [ $? -ne 0 ]; then err "yq update failed; $f unchanged"; rm -f "$tmp"; exit 1; fi
				mv "$tmp" "$f" || { err "rename failed; $f unchanged"; rm -f "$tmp"; exit 1; }
				exit 0
				;;
		esac
	fi

	# ======================================================================
	# ROLE READ PATH (unchanged resolver semantics)
	# ======================================================================
	case "$ROLE" in
		author) MODEL_ENV=OPSX_AUTHOR_MODEL;  PROV_ENV=OPSX_AUTHOR_PROVIDER; FM_MODEL=author_model;  FM_PROV=author_provider; Y_MODEL=author; Y_PROV=author_provider ;;
		review) MODEL_ENV=OPSX_REVIEW_MODELS; PROV_ENV=OPSX_REVIEW_PROVIDER; FM_MODEL=review_models; FM_PROV=review_provider; Y_MODEL=review; Y_PROV=review_provider ;;
		impl)   MODEL_ENV=OPSX_IMPL_MODEL;    PROV_ENV=OPSX_IMPL_PROVIDER;   FM_MODEL=impl_model;    FM_PROV=impl_provider;   Y_MODEL=impl;   Y_PROV=impl_provider ;;
	esac

	G_VAL=""; G_SRC=unset
	read_files_key_g() {
		G_VAL=""; G_SRC=unset
		if [ -n "$CHANGE" ] && [ -n "$ROOT" ]; then
			rv="$ROOT/openspec/changes/$CHANGE/review.md"
			if [ -f "$rv" ] && need_yq; then
				fm="$(extract_fm "$rv")"
				if [ -n "$fm" ]; then
					tmp="$(mktemp)"; printf '%s\n' "$fm" >"$tmp"
					v="$(yq_scalar "$tmp" "$1")"; rm -f "$tmp"
					[ -n "$v" ] && { G_VAL="$v"; G_SRC=change; return; }
				fi
			fi
		fi
		# project layer retired (design D7): no longer consulted.
		if [ -f "$USER_CFG" ] && need_yq; then
			v="$(yq_scalar "$USER_CFG" "$2")"; [ -n "$v" ] && { G_VAL="$v"; G_SRC=user; return; }
		fi
	}

	resolve_model() {
		RAW=""; SRC=unset
		ev="${!MODEL_ENV-}"
		if [ -n "${ev:-}" ]; then
			if [ "$ROLE" = review ]; then
				RAW="$(printf '%s' "$ev" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | grep -v '^$' || true)"
			else
				RAW="$ev"
			fi
			[ -n "$RAW" ] && { SRC=env; return; }
		fi
		if [ -n "$CHANGE" ] && [ -n "$ROOT" ]; then
			rv="$ROOT/openspec/changes/$CHANGE/review.md"
			if [ -f "$rv" ] && need_yq; then
				fm="$(extract_fm "$rv")"
				if [ -n "$fm" ]; then
					tmp="$(mktemp)"; printf '%s\n' "$fm" >"$tmp"
					if [ "$ROLE" = review ]; then RAW="$(yq_list "$tmp" "$FM_MODEL")"; else RAW="$(yq_scalar "$tmp" "$FM_MODEL")"; fi
					rm -f "$tmp"
					[ -n "$RAW" ] && { SRC=change; return; }
				fi
			fi
		fi
		# project layer retired (design D7): no longer consulted.
		if [ -f "$USER_CFG" ] && need_yq; then
			if [ "$ROLE" = review ]; then RAW="$(yq_list "$USER_CFG" "$Y_MODEL")"; else RAW="$(yq_scalar "$USER_CFG" "$Y_MODEL")"; fi
			[ -n "$RAW" ] && { SRC=user; return; }
		fi
	}

	resolve_provider() {
		PROVIDER=""
		pe="${!PROV_ENV-}"; if [ -n "${pe:-}" ]; then PROVIDER="$pe"; return; fi
		read_files_key_g "$FM_PROV" "$Y_PROV"; [ -n "$G_VAL" ] && { PROVIDER="$G_VAL"; return; }
		if [ -n "${OPSX_PROVIDER:-}" ]; then PROVIDER="$OPSX_PROVIDER"; return; fi
		read_files_key_g provider provider; [ -n "$G_VAL" ] && PROVIDER="$G_VAL"
	}

	qualify() {
		[ -z "$1" ] && return
		case "$1" in
			*/*) printf '%s' "$1" ;;
			*) if [ -n "${PROVIDER:-}" ]; then printf '%s/%s' "$PROVIDER" "$1"; else printf '%s' "$1"; fi ;;
		esac
	}

	if [ "$ROLE" = author-in-session ]; then
		AIS=""; ASRC=default
		ev="${OPSX_AUTHOR_IN_SESSION-}"
		if [ -n "${ev:-}" ]; then RAW_AIS="$ev"; ASRC=env
		else read_files_key_g author_in_session author_in_session; RAW_AIS="$G_VAL"; [ -n "$RAW_AIS" ] && ASRC="$G_SRC"; fi
		if [ -n "${RAW_AIS:-}" ]; then
			case "$(printf '%s' "$RAW_AIS" | tr 'A-Z' 'a-z')" in
				false|0|no) AIS=false ;;
				*) AIS=true ;;
			esac
		else
			AIS=true; ASRC=default
		fi
		if [ "$JSON" -eq 1 ]; then
			jq -cn --argjson v "$AIS" --arg s "$ASRC" '{value:$v,source:$s}'
		else
			printf '%s\n' "$AIS"
		fi
		exit 0
	fi

	resolve_model
	resolve_provider

	if [ "$SRC" = unset ]; then
		if [ "$JSON" -eq 1 ]; then
			if [ "$WITH_DEFAULT" -eq 1 ]; then jq -cn '{value:"session",source:"default"}'
			else jq -cn '{value:null,source:"unset"}'; fi
		else
			[ "$WITH_DEFAULT" -eq 1 ] && printf 'session\n'
		fi
		exit 0
	fi

	QUAL=""
	while IFS= read -r line; do
		[ -z "$line" ] && continue
		QUAL+="$(qualify "$line")"$'\n'
	done <<EOF
$RAW
EOF
	QUAL="${QUAL%$'\n'}"

	if [ "$JSON" -eq 1 ]; then
		if [ "$ROLE" = review ]; then
			printf '%s\n' "$QUAL" | jq -R -s --arg s "$SRC" '{value:(split("\n")|map(select(length>0))),source:$s}'
		else
			jq -cn --arg v "$QUAL" --arg s "$SRC" '{value:$v,source:$s}'
		fi
	else
		printf '%s\n' "$QUAL"
	fi
)

# ============================================================================
# SHARED WORKTREE DERIVATION (single source — opsx-cli.read-only-worktree-path-emit)
# The convention path and branch-lookup logic exist exactly once; `opsx worktree
# ensure`, `opsx worktree path`, and the gate's locator fallback all consume
# these helpers so no caller carries an independent copy of the derivation.
# ============================================================================
opsx_repo_main_root() { # $1=any-checkout root → the repo's MAIN (integration) worktree root
  git -C "$1" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print substr($0,10); exit}'
}
opsx_wt_convention_path() { # $1=any-checkout root $2=change → the path `ensure` would derive absent --path
  # Normalized to the MAIN worktree root so the derivation is IDENTICAL from the
  # integration checkout and from inside any linked worktree — gate-view equality
  # (intent invariant) breaks otherwise.
  local main
  main="$(opsx_repo_main_root "$1")"
  [ -n "$main" ] || main="$1"
  echo "$(dirname "$main")/$(basename "$main")--opsx-$2"
}
opsx_integration_branch() { # $1=repo-root [$2=change] → resolved integration branch on stdout; rc=1 when unresolvable
  # Deterministic resolver (opsx-cli.integration-branch-resolution), first hit wins:
  #   1. the change's review.md **Integration Branch:** field — trimmed, non-empty,
  #      and not a template placeholder (the shipped `<detected-at-capture>`
  #      sentinel; any `<...>` value is placeholder-shaped, never a real branch)
  #   2. `git symbolic-ref refs/remotes/origin/HEAD` short name
  #   3. local branch `main`      4. local branch `master`
  #   5. unresolvable → rc=1, NO output. The NAMED loud error is the blocking
  #      call sites' job (gate / archive-check); `opsx status` degrades to its
  #      stable placeholder instead (clarify C3). Pure git plumbing + file read;
  #      no model call, no config-override key (intent D1).
  local r="" b=""
  if [ -n "${2:-}" ] && [ -f "$1/openspec/changes/$2/review.md" ]; then
    r="$(grep -E '^\*\*Integration Branch:\*\*' "$1/openspec/changes/$2/review.md" 2>/dev/null | head -1 \
      | sed -E 's/^\*\*Integration Branch:\*\*[[:space:]]*//; s/[[:space:]]+$//')"
    case "$r" in "<"*) r="" ;; esac
    if [ -n "$r" ]; then echo "$r"; return 0; fi
  fi
  b="$(git -C "$1" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)"
  b="${b#origin/}"
  if [ -n "$b" ]; then echo "$b"; return 0; fi
  if git -C "$1" show-ref --verify --quiet refs/heads/main; then echo main; return 0; fi
  if git -C "$1" show-ref --verify --quiet refs/heads/master; then echo master; return 0; fi
  return 1
}
opsx_wt_for_branch() { # $1=repo-root $2=change → existing worktree checked out on opsx/<change>, if any
  git -C "$1" worktree list --porcelain 2>/dev/null | awk -v b="refs/heads/opsx/$2" '
    /^worktree /{wt=substr($0,10)} /^branch /{if (substr($0,8)==b) {print wt; exit}}'
}
opsx_wt_valid_for_change() { # $1=path $2=change → 0 iff a git worktree on branch opsx/<change>
  [ -n "$1" ] || return 1
  git -C "$1" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  [ "$(git -C "$1" rev-parse --abbrev-ref HEAD 2>/dev/null)" = "opsx/$2" ]
}

# ============================================================================
# MIGRATION SWEEP CORE (opsx-cli.migration-completeness-sweep-command,
# opsx-gate-enforcement.migration-sweep-gate-check). Shared by `opsx sweep`
# and the gate's conditional cheap check so both grep the SAME resolved
# checkout with the SAME semantics. Deterministic, model-free.
#   $1=checkout-root  $2=sweep.txt path
#   prints SWEEP-HIT <pattern> <file>:<line> / SWEEP-ERROR <pattern> lines
#   returns 0 clean · 1 hits · 2 pattern error (loud, never a silent pass)
# Swept surface: git-tracked files of the resolved checkout MINUS the
# non-deployed OpenSpec workspace (openspec/**) and ADR history (adr/**),
# which legitimately record retired vocabulary until/after archive.
# ============================================================================
opsx_sweep_run() {
  local root="$1" decl="$2" rc=0 pat out st
  while IFS= read -r pat || [ -n "$pat" ]; do
    # Trim surrounding whitespace so whitespace-only lines are blank (a lone
    # " " would otherwise become an ERE matching nearly every tracked line —
    # false-positive flood; opsx-workflow-schema "blank lines ignored").
    pat="${pat#"${pat%%[![:space:]]*}"}"
    pat="${pat%"${pat##*[![:space:]]}"}"
    case "$pat" in ''|'#'*) continue ;; esac
    out="$(git -C "$root" grep -nE -e "$pat" -- ':(exclude)openspec/**' ':(exclude)adr/**' 2>/dev/null)"; st=$?
    if [ "$st" -eq 0 ]; then
      printf '%s\n' "$out" | awk -F: -v p="$pat" '{print "SWEEP-HIT " p " " $1 ":" $2}'
      rc=1
    elif [ "$st" -ne 1 ]; then
      # grep/git error (malformed ERE, etc): loud tri-state, distinct from hit
      # and clean — never a silent exit 0 (analyze F6).
      echo "SWEEP-ERROR $pat"
      return 2
    fi
  done < "$decl"
  return "$rc"
}

# ============================================================================
# SUBCOMMAND: sweep — migration-completeness sweep for one change.
#   opsx sweep <change> [--worktree <path>]
# Resolves the implementation checkout EXACTLY as the gate does: explicit
# --worktree validated loudly; else the recorded Worktree Path locator; else
# the convention path when valid; else the integration checkout.
# ============================================================================
opsx_sweep() (
  set -u
  CHANGE="${1:-}"
  [ -n "$CHANGE" ] || { echo "opsx sweep: usage: opsx sweep <change> [--worktree <path>]" >&2; exit 2; }
  shift
  WT_ARG=""
  [ "${1:-}" = "--worktree" ] && { WT_ARG="${2:?opsx sweep: --worktree needs a path}"; shift 2; }
  ROOT="${OPSX_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}"
  [ -n "$ROOT" ] || { echo "opsx sweep: not inside a git repository" >&2; exit 2; }
  MAIN="$(opsx_repo_main_root "$ROOT")"; [ -n "$MAIN" ] || MAIN="$ROOT"
  ROOT="$MAIN"
  SWEEP_ROOT="$ROOT"
  if [ -n "$WT_ARG" ]; then
    # Operator assertion: validate NOW, fail LOUD — never a silent fallback.
    if ! opsx_wt_valid_for_change "$WT_ARG" "$CHANGE"; then
      echo "opsx sweep: explicit --worktree is not a git worktree on branch opsx/$CHANGE: $WT_ARG" >&2
      exit 2
    fi
    SWEEP_ROOT="$WT_ARG"
  else
    _REVIEW="$ROOT/openspec/changes/$CHANGE/review.md"
    WP=""
    if [ -f "$_REVIEW" ]; then
      WP="$(grep -E '^\*\*Worktree Path:\*\*' "$_REVIEW" 2>/dev/null | head -1 \
            | sed -E 's/^\*\*Worktree Path:\*\*[[:space:]]*//; s/[[:space:]]+$//')"
      case "$WP" in *"<empty"*|"<"*) WP="" ;; esac
    fi
    if opsx_wt_valid_for_change "$WP" "$CHANGE"; then
      SWEEP_ROOT="$WP"
    else
      _CAND="$(opsx_wt_convention_path "$ROOT" "$CHANGE")"
      if opsx_wt_valid_for_change "$_CAND" "$CHANGE"; then SWEEP_ROOT="$_CAND"; fi
    fi
  fi
  DECL="$SWEEP_ROOT/openspec/changes/$CHANGE/sweep.txt"
  if [ ! -f "$DECL" ]; then
    echo "opsx sweep: no sweep.txt declared for $CHANGE (clean pass)"
    exit 0
  fi
  opsx_sweep_run "$SWEEP_ROOT" "$DECL"
  exit $?
)

# ============================================================================
# SUBCOMMAND: gate
# ============================================================================
opsx_gate() (
# opsx gate <change> [--worktree <path>]
#
# Single (primary) source of enforcement truth for opsx-superpowers changes.
# Exit 0 = all required checks pass; the change is ready to archive.
# Exit non-zero = not ready; one stable line per failed check is printed to stderr:
#
#     GATE-FAIL <check_id> <blocking> <message>
#     GATE-WARN <check_id> 0 <message>
#
# Machine consumers rely on <check_id>, the <blocking> flag (1/0), and line order.
# Mode values are sourced ONLY from review.md YAML front-matter (never the prose
# table). Deterministic: no language-model judgment.
#
# Capability: opsx-gate-enforcement.
set -uo pipefail

PROG="opsx gate"
CHANGE=""
WORKTREE_ARG=""
CHEAP=0
while [ $# -gt 0 ]; do
  case "$1" in
    --worktree) { [ $# -ge 2 ] && [ -n "$2" ]; } || { echo "$PROG: --worktree requires a value" >&2; exit 2; }; WORKTREE_ARG="$2"; shift 2 ;;
    --cheap) CHEAP=1; shift ;;
    -h|--help) echo "usage: $PROG <change> [--worktree <path>] [--cheap]"; exit 0 ;;
    -*) echo "$PROG: unknown option $1" >&2; exit 2 ;;
    *) CHANGE="$1"; shift ;;
  esac
done
# --cheap (opsx-cli.status-fleet-view consumer, design D1): run ALL deterministic
# artifact/front-matter/verdict-state checks but SKIP validation-command execution
# and the Scale>=M validation-source enforcement, and do NOT exit at the cheap-
# checks short-circuit — so code-review/verify/doneness state still reports. The
# run is label-visible as gate(cheap) so a green never overclaims validations ran.
GLABEL="gate"; [ "$CHEAP" -eq 1 ] && GLABEL="gate(cheap)"
[ -n "$CHANGE" ] || { echo "usage: $PROG <change> [--worktree <path>]" >&2; exit 2; }

ROOT="$(git -C "${OPSX_ROOT:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" \
  || { echo "GATE-FAIL repo 1 not inside a git repository" >&2; exit 1; }
CDIR="$ROOT/openspec/changes/$CHANGE"
REVIEW="$CDIR/review.md"

rc=0
fail() { echo "GATE-FAIL $1 1 $2" >&2; rc=1; }
warn() { echo "GATE-WARN $1 0 $2" >&2; }

# --- front-matter reader: sole machine source, dependency-free (awk) ----------
fm() {
  # $1 = key. Prints the value from the YAML front-matter (between the first two
  # '---' fences). Empty if absent or if the file has no front-matter.
  [ -f "$REVIEW" ] || return 0
  awk -v key="$1" '
    NR==1 { if ($0 != "---") exit; infm=1; next }
    infm && $0=="---" { exit }
    infm {
      line=$0; sub(/^[ \t]+/,"",line)
      p=index(line,":"); if (p==0) next
      k=substr(line,1,p-1); v=substr(line,p+1)
      gsub(/^[ \t]+|[ \t]+$/,"",k); gsub(/^[ \t]+|[ \t]+$/,"",v)
      gsub(/^["'\'']|["'\'']$/,"",v)
      if (k==key) { print v; exit }
    }' "$REVIEW"
}

# --- body field reader (e.g. "**Diff Base SHA:** abc123") ---------------------
bodyfield() {
  [ -f "$REVIEW" ] || return 0
  grep -E "^\*\*$1:\*\*" "$REVIEW" 2>/dev/null \
    | head -1 | sed -E "s/^\*\*$1:\*\*[[:space:]]*//; s/[[:space:]]+$//"
}

# ============================================================================
# ARTIFACT SOURCE RESOLUTION (single source of truth)
# When a usable worktree is located (via --worktree or the recorded Worktree
# Path), ALL change artifacts — review.md modes, tasks.md, verify.md,
# code-review.md, doneness.md — are read from the WORKTREE checkout, which is
# where the apply workflow writes them (verdicts stay uncommitted there until
# gate-green). Reading them from the integration checkout while validating the
# worktree was the split-brain failure mode: a correct worktree could red-loop
# forever against stale root copies.
# ============================================================================
WT_PATH="$WORKTREE_ARG"
if [ -n "$WT_PATH" ]; then
  # An explicit --worktree is an operator assertion: validate it NOW and fail
  # LOUD on mismatch (any worktree_mode) — never silently ignore it or
  # substitute another tree (clarify C3).
  if ! opsx_wt_valid_for_change "$WT_PATH" "$CHANGE"; then
    fail worktree "explicit --worktree is not a git worktree on branch opsx/$CHANGE: $WT_PATH"
    echo "opsx gate: explicit worktree invalid (change=$CHANGE)" >&2
    exit 1
  fi
else
  WT_PATH="$(bodyfield 'Worktree Path')"
  case "$WT_PATH" in *"<empty"*|"<"*) WT_PATH="" ;; esac
  # Convention fallback (opsx-gate-enforcement.verdict-freshness-and-provenance):
  # ONLY when the RECORDED locator is absent/invalid, and ONLY the convention
  # path from the single-source derivation — --path-override worktrees are
  # covered by the committed locator, not the fallback (BY DESIGN).
  if ! opsx_wt_valid_for_change "$WT_PATH" "$CHANGE"; then
    _CAND="$(opsx_wt_convention_path "$ROOT" "$CHANGE")"
    if opsx_wt_valid_for_change "$_CAND" "$CHANGE"; then WT_PATH="$_CAND"; else WT_PATH=""; fi
  fi
fi
ART_ROOT="$ROOT"
if [ -n "$WT_PATH" ] \
   && git -C "$WT_PATH" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
   && [ -d "$WT_PATH/openspec/changes/$CHANGE" ]; then
  ART_ROOT="$WT_PATH"
  CDIR="$ART_ROOT/openspec/changes/$CHANGE"
  REVIEW="$CDIR/review.md"
fi

[ -d "$CDIR" ] || { fail change "change not found: $CHANGE"; exit 1; }

SCALE="$(fm scale)"
FULL_RIGOR_RAW="$(fm full_rigor)"
WORKTREE_MODE="$(fm worktree_mode)"
VERIFY_MODE="$(fm verification_mode)"
CR_MODE="$(fm code_review_mode)"
VSRC_MODE="$(fm validation_source_mode)"
DONE_MODE="$(fm doneness_mode)"

# Fail CLOSED on unknown values of enforcement-relevant modes: a typo like
# `worktree_requred`'s value must not silently disable enforcement. Empty is
# allowed (defaults apply); unknown non-empty values are a hard failure.
validate_mode() { # $1 = field name, $2 = value, $3 = allowed values (space-sep)
  [ -z "$2" ] && return 0
  case " $3 " in *" $2 "*) return 0 ;; esac
  fail mode "unknown $1 value: '$2' (allowed: $3); failing closed"
}
validate_mode worktree_mode "$WORKTREE_MODE" "worktree-required worktree-eligible same-tree"
validate_mode verification_mode "$VERIFY_MODE" "inline-only retained-recommended retained-required"
validate_mode code_review_mode "$CR_MODE" "none advisory gating-required"
validate_mode validation_source_mode "$VSRC_MODE" "required waived"
validate_mode doneness_mode "$DONE_MODE" "required waived"

# Derived fail-CLOSED default for the load-bearing review mode (R5-F1): an
# ABSENT code_review_mode must not read as "not gating-required" at Scale M —
# the documented default is gating-required at M+ (schema.yaml), advisory
# below. An omitted key at M previously let a change pass with no
# code-review.md at all (fail-open by omission).
if [ -z "$CR_MODE" ]; then
  case "$SCALE" in
    M) CR_MODE="gating-required" ;;
    *) CR_MODE="advisory" ;;
  esac
fi

# ============================================================================
# CHEAP CHECKS (structure / artifacts / tasks) — short-circuit before expensive
# ============================================================================

# Project-artifact preflight (opsx-gate-enforcement.project-artifact-preflight):
# constitution.md + domain.md must exist NON-EMPTY (size > 0, `test -s` — C2) at
# EVERY Scale. Fail-closed: no waiver key, no auto-scaffold; the remedy names the
# shipped templates. Ordered before review.md so a bare repo reds here first.
TPLDIR="~/.local/share/openspec/schemas/opsx-superpowers/templates"
if [ ! -s "$ROOT/openspec/constitution.md" ]; then
  fail project-artifacts "openspec/constitution.md absent or empty — scaffold from constitution-template.md under $TPLDIR (no waiver; required at every Scale)"
fi
if [ ! -s "$ROOT/openspec/domain.md" ]; then
  fail project-artifacts "openspec/domain.md absent or empty — scaffold from domain-template.md under $TPLDIR (no waiver; required at every Scale)"
fi

# review.md present + Scale parseable (Scale is read first; review ordered first)
if [ ! -f "$REVIEW" ]; then
  fail review "review.md absent (required to read Scale)"
fi
# Tier collapse (opsx-workflow-schema.scale-adaptive-gating, design D3): the
# vocabulary is XS|S|M. The retired L/XL labels fail CLOSED with the relabel
# remedy (former L/XL == "scale: M" + "full_rigor: true").
case "$SCALE" in
  XS|S|M) ;;
  L|XL) fail scale "Scale $SCALE retired; relabel to 'scale: M' + 'full_rigor: true' (former L/XL mapping)" ; SCALE="" ;;
  *) fail scale "Scale absent or unparseable in review.md front-matter" ; SCALE="" ;;
esac

# full_rigor: optional boolean front-matter flag. Absent => false; any value
# that is not a parseable boolean fails CLOSED (never silently defaulted).
FULL_RIGOR=false
case "$(printf '%s' "$FULL_RIGOR_RAW" | tr '[:upper:]' '[:lower:]')" in
  ""|false) FULL_RIGOR=false ;;
  true) FULL_RIGOR=true ;;
  *) fail full_rigor "unparseable full_rigor value: '$FULL_RIGOR_RAW' (expected true or false); failing closed" ;;
esac

# Required artifacts by (Scale, full_rigor), emitted in lifecycle dependency order.
# Plain M drops the standalone clarify.md/analyze.md (clarify open questions live
# in proposal, analyze is deterministic-checks-only); M + full_rigor restores the
# full former M/L/XL set. doneness is NOT a structural artifact here — it is a
# mode-conditioned verdict governed by the Doneness Verdict Enforcement section.
# D3 table (opsx-gate-enforcement.required-artifact-by-scale): review.md is
# always required (checked above; Scale is read from it). XS adds nothing; S
# adds proposal + tasks; plain M adds specs/intent/plan (design.md is NOT
# required at plain M — it is decision-gated authoring per D5); M+full_rigor
# adds clarify + analyze + design (the former L/XL full set always carried
# design). specs/ and plan are NOT required below M.
case "$SCALE" in
  XS) req="review" ;;
  S)  req="review proposal tasks" ;;
  M)  if [ "$FULL_RIGOR" = true ]; then
        req="review intent proposal specs clarify design analyze tasks plan"
      else
        req="review intent proposal specs tasks plan"
      fi ;;
  *)  req="" ;;
esac

# Worktree-mode default derivation (design D6): when worktree_mode is ABSENT from
# front-matter, derive it by tier — XS/S same-tree, M worktree-required. An
# explicit value (already validated above) always wins.
if [ -z "$WORKTREE_MODE" ]; then
  case "$SCALE" in
    XS|S) WORKTREE_MODE=same-tree ;;
    M)    WORKTREE_MODE=worktree-required ;;
  esac
fi
ORDER="review intent proposal specs clarify design analyze tasks plan"
for a in $ORDER; do
  case " $req " in *" $a "*) ;; *) continue ;; esac
  if [ "$a" = "specs" ]; then
    [ -d "$CDIR/specs" ] || fail "artifact-specs" "required artifact missing: specs/ ($SCALE)"
  else
    [ -f "$CDIR/$a.md" ] || fail "artifact-$a" "required artifact missing: $a.md ($SCALE)"
  fi
done

# Structural validation (OpenSpec-tracked artifacts only) — run against the
# resolved artifact source so worktree-side artifacts are what gets validated.
# Conditioned on specs/ (R6-F1): the real openspec CLI requires >=1 spec delta
# per change, but the D3 matrix deliberately omits specs/ at XS and S — an
# unconditional whole-change validate would make those tiers ungateable in a
# real workspace. Run it whenever specs/ EXISTS (any tier — authored deltas
# must always validate), skip it only when specs/ is both absent and not
# required by the tier matrix.
if command -v openspec >/dev/null 2>&1 && [ -d "$CDIR/specs" ]; then
  ( cd "$ART_ROOT" && openspec validate "$CHANGE" --strict --no-interactive ) >/dev/null 2>&1 \
    || fail structure "openspec validate --strict failed"
fi

# Migration sweep (opsx-gate-enforcement.migration-sweep-gate-check): runs ONLY
# when the change declares sweep.txt; greps the SAME resolved ART_ROOT the
# other artifact checks read (the validated worktree when resolved), so
# worktree-side fixes count and integration-side stale copies never false-fail.
# Undeclared changes: no check, exit code unaffected.
if [ -f "$CDIR/sweep.txt" ]; then
  sweep_out="$(opsx_sweep_run "$ART_ROOT" "$CDIR/sweep.txt")"; sweep_rc=$?
  [ -n "$sweep_out" ] && printf '%s\n' "$sweep_out" >&2
  if [ "$sweep_rc" -eq 1 ]; then
    fail sweep "declared pattern(s) hit shipped surfaces ($(printf '%s\n' "$sweep_out" | grep -c '^SWEEP-HIT' || true) hit(s))"
  elif [ "$sweep_rc" -ge 2 ]; then
    fail sweep "sweep declaration error: $(printf '%s\n' "$sweep_out" | grep '^SWEEP-ERROR' | head -1)"
  fi
fi

# Tasks complete
if [ -f "$CDIR/tasks.md" ]; then
  unchecked="$(grep -cE '^[[:space:]]*- \[ \]' "$CDIR/tasks.md" 2>/dev/null || true)"
  [ "${unchecked:-0}" -eq 0 ] || fail tasks "$unchecked unchecked task(s) in tasks.md"
fi

# In-Session Authoring Marker Check
# Spec: opsx-gate-enforcement.in-session-authoring-marker-check
#       opsx-model-config.author-in-session-by-default
# WHILE author_in_session is true/unset AND the `author` role is CONFIGURED
# (resolved via opsx-models, source != unset/default), every authoring artifact
# SHALL carry the literal marker `<!-- authored: in-session -->`. Resolver-absent,
# author unconfigured, or author_in_session=false => skip (no enforcement).
# In-process resolver (consolidated opsx): call the in-file `opsx_models`.
if command -v jq >/dev/null 2>&1; then
  author_src="$(OPSX_ROOT="$ART_ROOT" opsx_models author --json --change "$CHANGE" 2>/dev/null | jq -r '.source' 2>/dev/null || true)"
  ais="$(OPSX_ROOT="$ART_ROOT" opsx_models author-in-session --json --change "$CHANGE" 2>/dev/null | jq -r '.value' 2>/dev/null || true)"
  case "$author_src" in
    env|change|user)
      if [ "$ais" != "false" ]; then
        MARKER='<!-- authored: in-session -->'
        for f in "$CDIR/proposal.md" "$CDIR/intent.md" "$CDIR/design.md" "$CDIR/clarify.md" "$CDIR/tasks.md" "$CDIR/plan.md" "$CDIR"/specs/*/spec.md; do
          [ -f "$f" ] || continue
          grep -qF "$MARKER" "$f" \
            || fail author-marker "authoring artifact ${f#"$CDIR/"} lacks '$MARKER' (author role configured, author_in_session true)"
        done
      fi
      ;;
  esac
fi

# Short-circuit: do not run expensive validations while cheap checks are red.
# In --cheap mode the short-circuit is DISABLED (validations are skipped anyway)
# so verdict-state (verify/code-review/doneness) checks still run and report.
if [ "$rc" -ne 0 ] && [ "$CHEAP" -eq 0 ]; then
  echo "$PROG: cheap checks failed (change=$CHANGE scale=${SCALE:-?}); validations skipped" >&2
  exit 1
fi

# ============================================================================
# WORKTREE ENFORCEMENT (for validations + verdict freshness)
# WT_PATH/ART_ROOT were resolved up front (artifact source resolution); this
# section enforces worktree-required and derives the implementation HEAD.
# ============================================================================
DIFF_BASE="$(bodyfield 'Diff Base SHA')"

impl_head() {
  if [ -n "$WT_PATH" ] && [ -d "$WT_PATH" ]; then
    git -C "$WT_PATH" rev-parse HEAD 2>/dev/null
  else
    git -C "$ROOT" rev-parse HEAD 2>/dev/null
  fi
}
IMPL_HEAD="$(impl_head)"

if [ "$WORKTREE_MODE" = "worktree-required" ]; then
  # Must locate a real worktree on branch opsx/<change>; never fall back to ROOT.
  if [ -z "$WT_PATH" ]; then
    fail worktree "worktree-required but no Worktree Path recorded and no --worktree given"; exit 1
  fi
  if ! git -C "$WT_PATH" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    fail worktree "Worktree Path is not a git worktree: $WT_PATH"; exit 1
  fi
  WT_BRANCH="$(git -C "$WT_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null)"
  if [ "$WT_BRANCH" != "opsx/$CHANGE" ]; then
    fail worktree "worktree not on branch opsx/$CHANGE (on ${WT_BRANCH:-?})"; exit 1
  fi
fi

# ============================================================================
# EXPENSIVE: agent-independent validation source + manifest/OPSX_VALIDATE
# ============================================================================
MANIFEST="$ROOT/openspec/opsx-gates.yaml"
have_required_source=0

run_in_impl() {
  # Run a command with cwd = implementation worktree (or ROOT) + OPSX_* env,
  # bounded by a per-command timeout (default 600s; override with
  # OPSX_GATE_CMD_TIMEOUT). A hung validator must not wedge the loop: budget
  # and stall guards only run after the gate returns. Uses the portable
  # perl-alarm timeout (macOS has no coreutils `timeout`); if perl is absent
  # the command runs unbounded as before.
  local cwd="$ROOT"
  [ -n "$WT_PATH" ] && [ -d "$WT_PATH" ] && cwd="$WT_PATH"
  local tmo="${OPSX_GATE_CMD_TIMEOUT:-600}"
  if command -v perl >/dev/null 2>&1; then
    ( cd "$cwd" \
      && OPSX_CHANGE="$CHANGE" OPSX_CHANGE_DIR="$CDIR" OPSX_WORKTREE="$cwd" \
         OPSX_DIFF_BASE="$DIFF_BASE" OPSX_HEAD="$IMPL_HEAD" \
         perl -e 'my $t=shift @ARGV; alarm $t; exec @ARGV or die "exec: $!"' \
           "$tmo" bash -c "$1" ) >/dev/null 2>&1
  else
    ( cd "$cwd" \
      && OPSX_CHANGE="$CHANGE" OPSX_CHANGE_DIR="$CDIR" OPSX_WORKTREE="$cwd" \
         OPSX_DIFF_BASE="$DIFF_BASE" OPSX_HEAD="$IMPL_HEAD" \
         bash -c "$1" ) >/dev/null 2>&1
  fi
}

# In --cheap mode, skip ALL validation-command execution and the Scale>=M
# validation-source enforcement (design D1). Everything else (verdict-state,
# freshness, doneness) still runs below.
if [ "$CHEAP" -eq 0 ]; then
if [ -f "$MANIFEST" ] && command -v yq >/dev/null 2>&1; then
  gates_n="$(yq '.gates | length' "$MANIFEST" 2>/dev/null || echo 0)"
  i=0
  while [ "$i" -lt "${gates_n:-0}" ]; do
    gid="$(yq -r ".gates[$i].id" "$MANIFEST" 2>/dev/null)"
    grun="$(yq -r ".gates[$i].run" "$MANIFEST" 2>/dev/null)"
    # NOTE: avoid yq/jq `// true` here — jq treats boolean false as "empty",
    # so `.required // true` wrongly yields true for `required: false`.
    greq="$(yq -r ".gates[$i].required" "$MANIFEST" 2>/dev/null)"
    [ "$greq" = "null" ] || [ -z "$greq" ] && greq=true
    i=$((i+1))
    [ -n "$grun" ] && [ "$grun" != "null" ] || continue
    if [ "$greq" != "false" ]; then
      have_required_source=1
      run_in_impl "$grun" || fail "validation-$gid" "required gate failed: $grun"
    else
      run_in_impl "$grun" || warn "validation-$gid" "advisory gate failed: $grun"
    fi
  done
fi

# User-supplied gates (newline-separated)
if [ -n "${OPSX_VALIDATE:-}" ]; then
  have_required_source=1
  while IFS= read -r ucmd; do
    [ -n "$ucmd" ] || continue
    run_in_impl "$ucmd" || fail "validation-user" "user gate failed: $ucmd"
  done <<< "$OPSX_VALIDATE"
fi

# Scale >= M requires at least one agent-independent source unless waived.
case "$SCALE" in
  M)
    if [ "$have_required_source" -eq 0 ] && [ "$VSRC_MODE" != "waived" ]; then
      fail validation-source "Scale $SCALE requires an agent-independent validation source (manifest required:true or OPSX_VALIDATE); none found and validation_source_mode != waived"
    fi
    ;;
esac
fi  # end --cheap guard (validation-command execution + validation-source)

# ============================================================================
# MODE-AWARE VERDICTS + FRESHNESS/PROVENANCE
# ============================================================================
# Read a markdown field value ("**Name:** value" or "Name: value"), with leading
# HTML comments STRIPPED so a template's explanatory comment cannot satisfy a
# check, anchored to the field-name at line start. Value only (markup trimmed).
GW="$ROOT"; [ -n "$WT_PATH" ] && [ -d "$WT_PATH" ] && GW="$WT_PATH"
cr_field() { # $1=file $2=field name
  sed '/<!--/,/-->/d' "$1" 2>/dev/null \
    | grep -iE "^[*_ ]*$2[*_ ]*:" | head -1 \
    | sed -E "s/^[*_ ]*$2[*_ ]*:[*_ ]*//I; s/[*_[:space:]]+$//"
}
lc() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

# verify.md — enforced only when retained-required
VERIFY="$CDIR/verify.md"
if [ "$VERIFY_MODE" = "retained-required" ]; then
  if [ ! -f "$VERIFY" ]; then
    fail verify "verify.md absent (Verification Mode retained-required)"
  elif [ "$(lc "$(cr_field "$VERIFY" 'Status')")" != "green" ]; then
    fail verify "verify.md Completion Decision is not green"
  fi
fi

# code-review.md — enforced only when gating-required
CR="$CDIR/code-review.md"
if [ "$CR_MODE" = "gating-required" ]; then
  if [ ! -f "$CR" ]; then
    fail code-review "code-review.md absent (Code Review Mode gating-required)"
  else
    [ "$(lc "$(cr_field "$CR" 'Verdict')")" = "pass" ] \
      || fail code-review "code-review.md Verdict is not pass"
    [ "$(lc "$(cr_field "$CR" 'review_mode')")" = "degraded-single-model" ] \
      && fail code-review "code-review.md is degraded-single-model (does not satisfy gating/Constitution IX)"
    [ -n "$(cr_field "$CR" 'reviewer-provenance')" ] \
      || fail code-review "code-review.md lacks an adapter-stamped provenance field"
    # Attested HEAD (opsx-gate-enforcement.verdict-freshness-and-provenance):
    # reviewer-attested tree identity. MUST be a full 40-hex literal (verbatim
    # `git rev-parse HEAD` output) equal to the Reviewed Range head's full SHA.
    # Symbolic refs / short SHAs are UNPARSEABLE by design — never resolved in
    # the located worktree (a literal `HEAD` would trivially self-match there,
    # which is the exact wrong-tree bypass this field exists to close).
    att="$(cr_field "$CR" 'Attested HEAD')"
    if ! printf '%s' "$att" | grep -qE '^[0-9a-f]{40}$'; then
      fail code-review "code-review.md Attested HEAD absent or not a full 40-hex SHA literal (reviewer records verbatim 'git rev-parse HEAD'; symbolic/short forms fail closed)"
    else
      rr_att="$(cr_field "$CR" 'Reviewed Range')"
      rr_att_head="$(git -C "$GW" rev-parse "${rr_att##*..}" 2>/dev/null)"
      [ "$att" = "$rr_att_head" ] \
        || fail code-review "code-review.md Attested HEAD ($att) does not equal the Reviewed Range head (${rr_att##*..}) — wrong-tree verdict"
    fi
  fi
fi

# Verdict freshness: the recorded base..head must (after normalization) equal the
# current Diff Base..implementation HEAD. Under an ENFORCED mode the range and base
# are REQUIRED (their absence is a failed check, not a pass).
freshness_check() {
  local f="$1" cid="$2"
  [ -f "$f" ] || return 0
  local recorded base_rec
  recorded="$(cr_field "$f" 'Reviewed Range')"
  base_rec="$(cr_field "$f" 'Diff Base SHA')"
  if [ -z "$recorded" ] || [ -z "$base_rec" ]; then
    fail "$cid" "verdict missing Diff Base SHA / Reviewed Range (required when enforced)"; return
  fi
  local r_base="${recorded%%..*}" r_head="${recorded##*..}"
  local n_rbase n_rhead n_base n_head
  n_rbase="$(git -C "$GW" rev-parse "$r_base" 2>/dev/null)"
  n_rhead="$(git -C "$GW" rev-parse "$r_head" 2>/dev/null)"
  n_base="$(git -C "$GW" rev-parse "$DIFF_BASE" 2>/dev/null)"
  n_head="$(git -C "$GW" rev-parse "$IMPL_HEAD" 2>/dev/null)"
  if [ -z "$n_rbase" ] || [ -z "$n_rhead" ] || [ "$n_rbase" != "$n_base" ]; then
    fail "$cid" "stale verdict: reviewed base ${r_base} != current ${DIFF_BASE}"; return
  fi
  if [ "$n_rhead" = "$n_head" ]; then return; fi
  # The recorded head may TRAIL current HEAD only by verdict-sealing commits
  # (committing verify.md/code-review.md must not self-stale the range). Accept
  # iff recorded head is an ancestor of HEAD and the only files changed since are
  # this change's verify.md / code-review.md.
  if git -C "$GW" merge-base --is-ancestor "$n_rhead" "$n_head" 2>/dev/null; then
    local changed nonverdict
    changed="$(git -C "$GW" diff --name-only "$n_rhead" "$n_head" 2>/dev/null)"
    nonverdict="$(printf '%s\n' "$changed" | grep -vE "openspec/changes/$CHANGE/(verify|code-review|doneness)\.md$" | grep -v '^$' || true)"
    if [ -n "$nonverdict" ]; then
      fail "$cid" "stale verdict: code changed since review (${r_head}..HEAD touches non-verdict files)"
    fi
  else
    fail "$cid" "stale verdict: reviewed head ${r_head} is not an ancestor of current HEAD"
  fi
}
[ "$CR_MODE" = "gating-required" ] && freshness_check "$CR" code-review-stale
[ "$VERIFY_MODE" = "retained-required" ] && freshness_check "$VERIFY" verify-stale

# ============================================================================
# DONENESS VERDICT (intent-satisfaction) — mode-conditioned, parse-only.
# Spec: opsx-gate-enforcement.doneness-verdict-enforcement
#       opsx-gate-enforcement.mode-aware-verdict-reading
#       opsx-adversarial-review.{sealed-doneness-verdict-artifact,freshness-bound-verdict,
#                            anti-self-forge-provenance,scale-gated-with-waiver}
# Emitted ONLY as the sole remaining failure: while any mechanical/verify/code-review
# check is already red (rc != 0), the doneness line is suppressed (the load-bearing
# precondition the stall detector's gap-set signal depends on). No language-model call —
# the gate reads sealed doneness.md fields only.
# ============================================================================
[ -n "$DONE_MODE" ] || DONE_MODE=required
DONE="$CDIR/doneness.md"
sha256_file() {
  if command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" 2>/dev/null | awk '{print $1}';
  else sha256sum "$1" 2>/dev/null | awk '{print $1}'; fi
}
# A doneness_waiver_rationale counts as present ONLY with real content: an inline
# scalar that is not merely a YAML block-scalar marker (>, |, >-, ...), OR a block
# scalar (`: >`/`: |`) followed by >=1 indented non-blank, non-comment line. This
# stops a content-less `doneness_waiver_rationale: >` from passing as a rationale.
waiver_has_rationale() {
  [ -f "$REVIEW" ] || return 1
  awk '
    /^---[[:space:]]*$/ { infm++; next }
    infm==1 {
      # Under a block scalar, an indented NON-blank NON-comment line is real content.
      if (inblock) {
        if ($0 ~ /^[[:space:]]+[^[:space:]#]/) { found=1; exit }
        if ($0 ~ /^[^[:space:]]/) inblock=0
      }
      if ($0 ~ /^doneness_waiver_rationale[[:space:]]*:/) {
        v=$0; sub(/^[^:]*:[[:space:]]*/,"",v)
        # Normalize the inline value: unwrap quotes, else strip an inline/whole-line
        # YAML comment, then trim, so comment-only / whitespace-only / bare block
        # markers do NOT count as a rationale.
        if (v ~ /^"/)       { sub(/^"/,"",v); sub(/".*$/,"",v) }
        else if (v ~ /^\x27/) { sub(/^\x27/,"",v); sub(/\x27.*$/,"",v) }
        else               { sub(/[[:space:]]#.*$/,"",v); sub(/^#.*$/,"",v) }
        gsub(/^[[:space:]]+|[[:space:]]+$/,"",v)
        if (v ~ /^[>|][+-]?$/)   { inblock=1 }      # block scalar: content is on later lines
        else if (v != "")        { found=1; exit }  # real inline scalar
      }
    }
    END { exit(found?0:1) }
  ' "$REVIEW"
}
if [ "$rc" -eq 0 ]; then
  case "$SCALE" in
    M)
      if [ "$DONE_MODE" = "waived" ]; then
        # Bare waiver (no real rationale) cannot bypass the judge at Scale>=M.
        if ! waiver_has_rationale; then
          fail doneness "doneness_mode: waived without a non-empty doneness_waiver_rationale (Scale $SCALE)"
        fi
      else
        # doneness_mode == required
        if [ ! -f "$DONE" ]; then
          fail doneness "doneness.md absent (doneness_mode required, Scale $SCALE)"
        elif [ "$(lc "$(cr_field "$DONE" 'Doneness')")" != "satisfied" ]; then
          fail doneness "doneness.md Doneness is not satisfied"
        else
          [ -n "$(cr_field "$DONE" 'Judge')" ] \
            || fail doneness "doneness.md lacks an adapter-stamped Judge provenance field"
          # Vocabulary (opsx-adversarial-review): blind-single-judge is the normal
          # single independent blind judge; adversarial-multimodel is the
          # stronger optional form. degraded-single-model (inline, no adapter)
          # and any unknown value fail CLOSED.
          dmode="$(lc "$(cr_field "$DONE" 'review_mode')")"
          case "$dmode" in
            blind-single-judge|adversarial-multimodel) ;;
            *) fail doneness "doneness.md provenance review_mode is '${dmode:-missing}' (need blind-single-judge or adversarial-multimodel; no independent blind judge established)" ;;
          esac
          i_rec="$(cr_field "$DONE" 'Frozen-Intent SHA')"
          i_now="$(sha256_file "$CDIR/intent.md")"
          if [ -z "$i_rec" ] || [ "$i_rec" != "$i_now" ]; then
            fail doneness "doneness.md judged against a mismatched intent hash"
          fi
          db_rec="$(cr_field "$DONE" 'Diff Base SHA')"
          if [ -n "$DIFF_BASE" ] && [ "$db_rec" != "$DIFF_BASE" ]; then
            fail doneness "doneness.md recorded Diff Base != review.md Diff Base"
          fi
          # Attested HEAD binding — ONLY for the independently dispatched
          # full_rigor judge (opsx-gate-enforcement.verdict-freshness-and-
          # provenance). Plain-M rides the combined CR dispatch: its reviewer's
          # attestation is already bound via code-review.md, so nothing is
          # demanded of doneness.md there (clarify C2 → Option A).
          if [ "$FULL_RIGOR" = true ]; then
            datt="$(cr_field "$DONE" 'Attested HEAD')"
            if ! printf '%s' "$datt" | grep -qE '^[0-9a-f]{40}$'; then
              fail doneness "doneness.md Attested HEAD absent or not a full 40-hex SHA literal (independent full_rigor judge must attest verbatim 'git rev-parse HEAD')"
            else
              d_head="$(git -C "$GW" rev-parse "$IMPL_HEAD" 2>/dev/null)"
              [ "$datt" = "$d_head" ] \
                || fail doneness "doneness.md Attested HEAD ($datt) does not equal the implementation HEAD — wrong-tree judge verdict"
            fi
          fi
          freshness_check "$DONE" doneness   # stale doneness fails under the 'doneness' check id-stale
        fi
      fi
      ;;
  esac
fi

# ============================================================================
if [ "$rc" -eq 0 ]; then
  if [ "$CHEAP" -eq 1 ]; then
    echo "GATE-PASS(cheap): $CHANGE (${SCALE:-?}) [validations not run]"
  else
    echo "GATE-PASS: $CHANGE (${SCALE:-?})"
  fi
  exit 0
fi
[ "$CHEAP" -eq 1 ] && echo "$PROG: $GLABEL red (change=$CHANGE scale=${SCALE:-?})" >&2
exit 1

)

# ============================================================================
# SUBCOMMAND: loop
# ============================================================================
opsx_loop() (
# opsx loop <change> [--worktree <path>]
#
# Harness-agnostic Ralph-style fallback driver for the opsx drive-to-completion
# loop. Repeatedly invokes a headless agent until `opsx gate <change>` exits 0.
# This is the PORTABILITY fallback: the primary path is the in-harness
# orchestrator (openspec-loop skill driven by the goal extension's command-judge).
# Swap harness by changing AGENT_CMD only.
#
#   AGENT_CMD   headless agent invocation (default: 'pi -p')
#               e.g. 'claude -p --dangerously-skip-permissions' | 'codex exec'
#   MAX_ITERS   iteration budget (default: review.md loop_max_iterations or 40)
#
# Capability: opsx-loop (fallback continuation).
set -uo pipefail

CHANGE="${1:?usage: opsx loop <change> [--worktree <path>]}"; shift || true
WT_PATH=""
[ "${1:-}" = "--worktree" ] && { WT_PATH="${2:?}"; shift 2; }

: "${AGENT_CMD:=pi -p}"
ROOT="$(git rev-parse --show-toplevel)"
CDIR="$ROOT/openspec/changes/$CHANGE"
PROMPT="$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/../share/openspec/schemas/opsx-superpowers/opsx-PROMPT.md"
[ -f "$PROMPT" ] || PROMPT="$HOME/.local/share/openspec/schemas/opsx-superpowers/opsx-PROMPT.md"

# Budget: explicit MAX_ITERS, else review.md front-matter loop_max_iterations,
# else 40. Parser is STRICT (whole value must be a positive integer; `80junk`,
# `-1`, `abc80` are unparseable → default), matching the pi extension's parser.
# DELIBERATE fallback exception: the extension treats an unparseable budget as
# unbounded (it has stall detection to terminate); this headless driver has no
# stall guard, so unbounded would risk an infinite agent loop — it defaults to
# a bounded 40 instead.
if [ -z "${MAX_ITERS:-}" ]; then
  MAX_ITERS="$(awk '
    NR==1{ if($0!="---") exit; next } $0=="---"{exit}
    /^[[:space:]]*loop_max_iterations[[:space:]]*:/{
      if (match($0, /^[[:space:]]*loop_max_iterations[[:space:]]*:[[:space:]]*[1-9][0-9]*[[:space:]]*$/)) {
        v=$0; sub(/^[^:]*:[[:space:]]*/,"",v); gsub(/[[:space:]]/,"",v); print v
      }
      exit
    }' \
    "$CDIR/review.md" 2>/dev/null)"
  : "${MAX_ITERS:=40}"
fi

gate() {
  if [ -n "$WT_PATH" ]; then opsx_gate "$CHANGE" --worktree "$WT_PATH"
  else opsx_gate "$CHANGE"; fi
}

i=0
while ! report="$(gate 2>&1)"; do
  i=$((i+1))
  if [ "$i" -gt "$MAX_ITERS" ]; then
    echo "opsx loop: budget exhausted ($MAX_ITERS); worktree preserved for inspection" >&2
    echo "$report" >&2
    exit 2
  fi
  echo "── opsx loop iter $i/$MAX_ITERS: gate red ──" >&2
  {
    [ -f "$PROMPT" ] && cat "$PROMPT"
    printf '\n\nCHANGE=%s\nopsx gate reports (fix the earliest blocking line first):\n%s\n' \
      "$CHANGE" "$report"
  } | $AGENT_CMD
done
echo "✅ opsx loop: $CHANGE — gate green. Ready to archive."

)


# ============================================================================
# SUBCOMMAND: worktree — deterministic worktree lifecycle (runtime-owned).
# `opsx worktree ensure <change>` creates or reuses the opsx/<change> worktree
# with the spec's exact semantics (opsx-workflow-schema.worktree-lifecycle-
# ownership): creation failure ABORTS (exit 1, actionable message); branch
# reuse PRESERVES the recorded immutable Diff Base SHA and HALTS if it is
# absent or not an ancestor of opsx/<change>. Prints the locator fields for
# review.md in a stable machine-readable form. Skills call this instead of
# hand-rolling git worktree commands, so lifecycle enforcement is
# deterministic rather than prose-driven.
# ============================================================================
opsx_worktree() (
set -uo pipefail
PROG="opsx worktree"
err() { echo "$PROG: $*" >&2; }
VERB="${1:-}"; [ $# -gt 0 ] && shift || true
case "$VERB" in
  ensure|path) ;;
  *) echo "usage: $PROG ensure <change> [--path <p>] [--integration-branch <b>] | $PROG path <change>" >&2; exit 2 ;;
esac
CHANGE=""; WPATH=""; IBRANCH=""
while [ $# -gt 0 ]; do
  case "$1" in
    --path) { [ $# -ge 2 ] && [ -n "$2" ]; } || { err "--path requires a value"; exit 2; }; WPATH="$2"; shift 2 ;;
    --integration-branch) { [ $# -ge 2 ] && [ -n "$2" ]; } || { err "--integration-branch requires a value"; exit 2; }; IBRANCH="$2"; shift 2 ;;
    -*) err "unknown option: $1"; exit 2 ;;
    *) CHANGE="$1"; shift ;;
  esac
done
[ -n "$CHANGE" ] || { echo "usage: $PROG ensure <change> [--path <p>] [--integration-branch <b>] | $PROG path <change>" >&2; exit 2; }

ROOT="$(git -C "${OPSX_ROOT:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" \
  || { err "not inside a git repository"; exit 1; }
[ -d "$ROOT/openspec/changes/$CHANGE" ] || { err "change not found: $CHANGE"; exit 1; }
BRANCH="opsx/$CHANGE"
REVIEW="$ROOT/openspec/changes/$CHANGE/review.md"

if [ "$VERB" = "path" ]; then
  # READ-ONLY emit (opsx-cli.read-only-worktree-path-emit): ONLY the canonical
  # convention path — the path `ensure` would derive absent a --path override.
  # Deliberately NOT the existing-branch-worktree lookup: --path-override
  # worktrees are out of the fallback's reach BY DESIGN (the committed locator
  # covers them). NO side effects.
  [ -z "$WPATH" ] && [ -z "$IBRANCH" ] || { err "path takes no options"; exit 2; }
  opsx_wt_convention_path "$ROOT" "$CHANGE"
  exit 0
fi

if [ -z "$IBRANCH" ]; then
  # Capture-time detection (opsx-workflow-schema.integration-branch-locator-
  # default-detected): fill the locator via the deterministic resolver steps 2-4
  # (no change arg — the locator field is what THIS capture writes, so step 1
  # cannot apply). Fallback: current branch (pre-resolver behavior) with the
  # detached-HEAD guard; explicit --integration-branch always wins.
  IBRANCH="$(opsx_integration_branch "$ROOT")" || IBRANCH=""
  if [ -z "$IBRANCH" ]; then
    IBRANCH="$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    if [ -z "$IBRANCH" ] || [ "$IBRANCH" = "HEAD" ]; then
      err "repository is in detached HEAD state; pass --integration-branch explicitly"; exit 1
    fi
  fi
fi
[ -n "$WPATH" ] || WPATH="$(opsx_wt_convention_path "$ROOT" "$CHANGE")"

recorded_base() {
  [ -f "$REVIEW" ] || return 0
  grep -E '^\*\*Diff Base SHA:\*\*' "$REVIEW" 2>/dev/null \
    | head -1 | sed -E 's/^\*\*Diff Base SHA:\*\*[[:space:]]*//; s/[[:space:]]+$//'
}

existing_wt_for_branch() { opsx_wt_for_branch "$ROOT" "$CHANGE"; }

if git -C "$ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
  # REUSE: preserve the recorded base; halt for human repair when unsafe.
  BASE="$(recorded_base)"
  case "$BASE" in "<"*) BASE="" ;; esac
  if [ -z "$BASE" ]; then
    err "branch $BRANCH exists but review.md has no recorded Diff Base SHA — HALT for human repair (re-recording a base would exclude unverified commits)"; exit 1
  fi
  if ! git -C "$ROOT" merge-base --is-ancestor "$BASE" "$BRANCH" 2>/dev/null; then
    err "recorded Diff Base SHA ($BASE) is not an ancestor of $BRANCH — HALT for human repair"; exit 1
  fi
  EXISTING="$(existing_wt_for_branch)"
  if [ -n "$EXISTING" ]; then
    WPATH="$EXISTING"
  else
    if ! git -C "$ROOT" worktree add "$WPATH" "$BRANCH" >/dev/null 2>&1; then
      err "worktree add failed for existing branch $BRANCH at $WPATH (path conflict / permissions / disk?) — ABORT, do not proceed to implementation"; exit 1
    fi
  fi
  MODE=reused
else
  if ! git -C "$ROOT" worktree add -b "$BRANCH" "$WPATH" "$IBRANCH" >/dev/null 2>&1; then
    err "worktree creation failed (branch $BRANCH at $WPATH from $IBRANCH: path conflict / permissions / disk / bad base?) — ABORT, do not proceed to implementation"; exit 1
  fi
  BASE="$(git -C "$ROOT" merge-base "$IBRANCH" "$BRANCH" 2>/dev/null)"
  if [ -z "$BASE" ]; then
    git -C "$ROOT" worktree remove --force "$WPATH" >/dev/null 2>&1
    git -C "$ROOT" branch -D "$BRANCH" >/dev/null 2>&1
    err "could not compute merge-base($IBRANCH, $BRANCH) — ABORT"; exit 1
  fi
  MODE=created
fi

# Stable machine-readable locator block (callers write these into review.md).
echo "WORKTREE-OK $MODE"
echo "Diff Base SHA: $BASE"
echo "Worktree Path: $WPATH"
echo "Integration Branch: $IBRANCH"
exit 0
)

# ============================================================================
# SUBCOMMAND: clean — remove an ABANDONED change's worktree + opsx/<change>
# branch. The archive path removes worktrees on merge; nothing else ever did,
# so abandoned changes leaked worktrees/branches (often holding uncommitted
# verdict files). Refuses when the worktree is dirty unless --force.
# ============================================================================
opsx_clean() (
set -uo pipefail
PROG="opsx clean"
err() { echo "$PROG: $*" >&2; }
CHANGE=""; FORCE=0
while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=1; shift ;;
    -*) err "unknown option: $1"; exit 2 ;;
    *) CHANGE="$1"; shift ;;
  esac
done
[ -n "$CHANGE" ] || { echo "usage: $PROG <change> [--force]" >&2; exit 2; }
ROOT="$(git -C "${OPSX_ROOT:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" \
  || { err "not inside a git repository"; exit 1; }
BRANCH="opsx/$CHANGE"

WT="$(git -C "$ROOT" worktree list --porcelain 2>/dev/null | awk -v b="refs/heads/$BRANCH" '
  /^worktree /{wt=substr($0,10)} /^branch /{if (substr($0,8)==b) {print wt; exit}}')"

did=0
if [ -n "$WT" ] && [ -d "$WT" ]; then
  dirty="$(git -C "$WT" status --porcelain 2>/dev/null | head -1)"
  if [ -n "$dirty" ] && [ "$FORCE" -ne 1 ]; then
    err "worktree $WT has uncommitted changes (possibly unsealed verify/code-review/doneness verdicts) — refusing; inspect it or re-run with --force"; exit 1
  fi
  if [ "$FORCE" -eq 1 ]; then
    git -C "$ROOT" worktree remove --force "$WT" >/dev/null 2>&1 || { err "worktree remove failed: $WT"; exit 1; }
  else
    git -C "$ROOT" worktree remove "$WT" >/dev/null 2>&1 || { err "worktree remove failed: $WT"; exit 1; }
  fi
  did=1
fi
if git -C "$ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
  git -C "$ROOT" branch -D "$BRANCH" >/dev/null 2>&1 || { err "branch delete failed: $BRANCH"; exit 1; }
  did=1
fi
if [ "$did" -eq 1 ]; then echo "CLEAN-OK $CHANGE"; else echo "CLEAN-OK $CHANGE (nothing to clean)"; fi
exit 0
)

# ============================================================================
# SUBCOMMAND: status — READ-ONLY, model-free fleet view (opsx-cli.status-fleet-view).
# Scans non-archive openspec/changes/*; per change prints Scale (+full_rigor),
# the gate(cheap) red/green summary + earliest failing check (reusing opsx gate
# --cheap), worktree path + valid|invalid|none on branch opsx/<change>, loop_hold
# + reason, and Diff Base staleness (commits behind the RESOLVED integration
# branch — opsx-cli.integration-branch-resolution). NO side effects, NO
# model calls, exit 0 ALWAYS — a view, never a gate.
# ============================================================================
opsx_status() (
set -uo pipefail
PROG="opsx status"
ROOT="$(git -C "${OPSX_ROOT:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" \
  || { echo "$PROG: not inside a git repository (nothing to view)" >&2; exit 0; }
CHANGES_DIR="$ROOT/openspec/changes"
[ -d "$CHANGES_DIR" ] || { echo "$PROG: no openspec/changes/ under $ROOT"; exit 0; }

fm_of() { # $1=review.md $2=key — read a value from the YAML front-matter
  [ -f "$1" ] || return 0
  awk -v key="$2" '
    NR==1 { if ($0 != "---") exit; infm=1; next }
    infm && $0=="---" { exit }
    infm {
      line=$0; sub(/^[ \t]+/,"",line)
      p=index(line,":"); if (p==0) next
      k=substr(line,1,p-1); v=substr(line,p+1)
      gsub(/^[ \t]+|[ \t]+$/,"",k); gsub(/^[ \t]+|[ \t]+$/,"",v)
      gsub(/^["'\'']|["'\'']$/,"",v)
      if (k==key) { print v; exit }
    }' "$1"
}
body_of() { # $1=review.md $2=field — read a **Field:** value line
  [ -f "$1" ] || return 0
  grep -E "^\*\*$2:\*\*" "$1" 2>/dev/null | head -1 \
    | sed -E "s/^\*\*$2:\*\*[[:space:]]*//; s/[[:space:]]+$//"
}

found=0
for d in "$CHANGES_DIR"/*; do
  [ -d "$d" ] || continue
  name="$(basename "$d")"
  [ "$name" = "archive" ] && continue
  found=1
  review="$d/review.md"

  # Scale (+full_rigor marker); placeholder when review.md/Scale absent.
  scale="$(fm_of "$review" scale)"
  if [ -z "$scale" ]; then
    scale_disp="—"
  else
    scale_disp="$scale"
    case "$(printf '%s' "$(fm_of "$review" full_rigor)" | tr '[:upper:]' '[:lower:]')" in
      true) scale_disp="$scale +full_rigor" ;;
    esac
  fi

  # gate(cheap) red/green + earliest failing check (reuse opsx gate --cheap).
  gout="$(OPSX_ROOT="$ROOT" opsx_gate "$name" --cheap 2>&1)"; grc=$?
  if [ "$grc" -eq 0 ]; then
    gate_disp="green"
  else
    earliest="$(printf '%s\n' "$gout" | grep -m1 '^GATE-FAIL ' | awk '{print $2}')"
    gate_disp="red [${earliest:-unknown}]"
  fi

  # worktree path + valid|invalid|none on branch opsx/<change>.
  if git -C "$ROOT" show-ref --verify --quiet "refs/heads/opsx/$name"; then
    wt="$(opsx_wt_for_branch "$ROOT" "$name")"
    if [ -n "$wt" ] && opsx_wt_valid_for_change "$wt" "$name"; then
      wt_disp="valid $wt"
    else
      [ -n "$wt" ] || wt="$(opsx_wt_convention_path "$ROOT" "$name")"
      wt_disp="invalid $wt"
    fi
  else
    wt_disp="none —"
  fi

  # loop_hold + reason (or placeholder).
  case "$(printf '%s' "$(fm_of "$review" loop_hold)" | tr '[:upper:]' '[:lower:]')" in
    true) hr="$(fm_of "$review" loop_hold_reason)"; hold_disp="held — ${hr:-(none)}" ;;
    *)    hold_disp="—" ;;
  esac

  # Diff Base staleness: N behind the RESOLVED integration branch (per-change;
  # opsx-cli.integration-branch-resolution). Placeholder when locator absent or
  # the branch is unresolvable — status is a view, never a loud failure (C3).
  base="$(body_of "$review" 'Diff Base SHA')"
  case "$base" in ""|"<"*) base="" ;; esac
  ib="$(opsx_integration_branch "$ROOT" "$name")" || ib=""
  if [ -n "$base" ] && [ -n "$ib" ] \
     && git -C "$ROOT" rev-parse --verify --quiet "refs/heads/$ib" >/dev/null 2>&1 \
     && git -C "$ROOT" rev-parse --verify --quiet "$base" >/dev/null 2>&1; then
    n="$(git -C "$ROOT" rev-list --count "$base..$ib" 2>/dev/null)"
    base_disp="${n:-?} behind $ib"
  else
    base_disp="—"
  fi

  printf '%s\n' "$name"
  printf '  Scale: %s\n' "$scale_disp"
  printf '  gate(cheap): %s\n' "$gate_disp"
  printf '  worktree: %s\n' "$wt_disp"
  printf '  loop_hold: %s\n' "$hold_disp"
  printf '  base: %s\n' "$base_disp"
done
[ "$found" -eq 1 ] || echo "$PROG: no non-archive changes under $CHANGES_DIR"
exit 0
)

# ============================================================================
# SUBCOMMAND: archive-check — deterministic archive/land preconditions
# (opsx-gate-enforcement.land-base-currency + .duplicate-adr-number-scan,
#  opsx-cli.multi-dir-integration-commit-detector). Exit non-zero IFF the
# land-base-currency (a) or duplicate-ADR (b) check fails; the multi-dir
# detector (c) is ADVISORY and NEVER affects the exit code. Model-free.
# ============================================================================
opsx_archive_check() (
set -uo pipefail
PROG="opsx archive-check"
err() { echo "$PROG: $*" >&2; }
CHANGE=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) echo "usage: $PROG <change>"; exit 0 ;;
    -*) err "unknown option: $1"; exit 2 ;;
    *) CHANGE="$1"; shift ;;
  esac
done
[ -n "$CHANGE" ] || { echo "usage: $PROG <change>" >&2; exit 2; }
ROOT="$(git -C "${OPSX_ROOT:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" \
  || { err "not inside a git repository"; exit 1; }
CDIR="$ROOT/openspec/changes/$CHANGE"
[ -d "$CDIR" ] || { err "change not found: $CHANGE"; exit 1; }
REVIEW="$CDIR/review.md"
BRANCH="opsx/$CHANGE"
rc=0

# (a) land-base-currency: merge-base(opsx/<change>, <integration branch>) must
#     equal the resolved integration branch's HEAD (opsx-cli.integration-branch-
#     resolution — never a hardcoded literal). No opsx/<change> branch =>
#     same-tree exemption (satisfied, never a missing-ref failure).
IB="$(opsx_integration_branch "$ROOT" "$CHANGE")" || IB=""
if git -C "$ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
  if [ -z "$IB" ]; then
    echo "ARCHIVE-CHECK-FAIL base-currency: integration branch unresolvable (no committed review.md Integration Branch field, no origin/HEAD, no main, no master)" >&2
    rc=1
  else
    mh="$(git -C "$ROOT" rev-parse "refs/heads/$IB" 2>/dev/null)"
    mb="$(git -C "$ROOT" merge-base "$BRANCH" "$IB" 2>/dev/null)"
    if [ -z "$mh" ] || [ -z "$mb" ]; then
      echo "ARCHIVE-CHECK-FAIL base-currency: cannot compute merge-base($BRANCH, $IB)" >&2
      rc=1
    elif [ "$mb" != "$mh" ]; then
      echo "ARCHIVE-CHECK-FAIL base-currency: stale base merge-base($BRANCH, $IB)=$mb != $IB HEAD=$mh; REMEDY: rebase $BRANCH onto $IB HEAD, then re-run review (the rebase staleness-fires a fresh review)" >&2
      rc=1
    else
      echo "archive-check: base-currency OK (merge-base($BRANCH, $IB) == $IB HEAD)"
    fi
  fi
else
  echo "archive-check: base-currency satisfied — no $BRANCH branch (same-tree exemption; no divergent base to rebase)"
fi

# (b) duplicate-ADR scan: derive ADR-NNNN from filenames under adr/.
if [ -d "$ROOT/adr" ]; then
  tmpn="$(mktemp)"
  for f in "$ROOT"/adr/*; do
    [ -f "$f" ] || continue
    b="$(basename "$f")"
    case "$b" in
      ADR-[0-9][0-9][0-9][0-9]*) n="$(printf '%s' "$b" | sed -E 's/^ADR-([0-9]{4}).*/\1/')"; printf '%s\t%s\n' "$n" "$f" >>"$tmpn" ;;
    esac
  done
  for n in $(awk -F'\t' '{print $1}' "$tmpn" | sort | uniq -d); do
    paths="$(awk -F'\t' -v k="$n" '$1==k{print $2}' "$tmpn" | paste -sd' ' -)"
    echo "ARCHIVE-CHECK-FAIL adr-dup: ADR-$n claimed by >=2 files: $paths" >&2
    rc=1
  done
  rm -f "$tmpn"
fi

# (c) multi-dir integration-commit detector (ADVISORY — never affects rc):
#     scan <Diff Base SHA>..<resolved integration branch> (first-parent chain,
#     MERGES INCLUDED — an
#     "evil merge" landing >=2 change dirs must be flagged per
#     opsx-cli.multi-dir-integration-commit-detector; a merge commit's touched
#     set is its net effect on the integration branch, i.e. diff vs its FIRST
#     parent) for any
#     commit touching >=2 distinct openspec/changes/<dir>/ directories.
#     Skipped when no Diff Base locator.
DIFF_BASE=""
[ -f "$REVIEW" ] && DIFF_BASE="$(grep -E '^\*\*Diff Base SHA:\*\*' "$REVIEW" 2>/dev/null | head -1 | sed -E 's/^\*\*Diff Base SHA:\*\*[[:space:]]*//; s/[[:space:]]+$//')"
case "$DIFF_BASE" in ""|"<"*) DIFF_BASE="" ;; esac
if [ -n "$DIFF_BASE" ] && [ -n "$IB" ] \
   && git -C "$ROOT" rev-parse --verify --quiet "refs/heads/$IB" >/dev/null 2>&1 \
   && git -C "$ROOT" rev-parse --verify --quiet "$DIFF_BASE" >/dev/null 2>&1; then
  for c in $(git -C "$ROOT" rev-list --first-parent "$DIFF_BASE..$IB" 2>/dev/null); do
    dirs="$(git -C "$ROOT" diff-tree --no-commit-id --name-only -r -m --first-parent "$c" 2>/dev/null \
      | sed -nE 's#^(openspec/changes/[^/]+)/.*#\1#p' | sort -u | grep -v '^$')"
    cnt="$(printf '%s\n' "$dirs" | grep -c . )"
    if [ "${cnt:-0}" -ge 2 ]; then
      echo "archive-check: ADVISORY multi-dir commit $c touches: $(printf '%s' "$dirs" | paste -sd' ' -) (path-scoped-commit backstop; advisory only, does NOT affect exit)"
    fi
  done
fi

exit $rc
)

# ============================================================================
# DISPATCH
# ============================================================================
sub="${1:-}"
[ $# -gt 0 ] && shift || true
case "$sub" in
  gate)          opsx_gate "$@"; exit $? ;;
  models)        opsx_models "$@"; exit $? ;;
  status)        opsx_status "$@"; exit $? ;;
  sweep)         opsx_sweep "$@"; exit $? ;;
  archive-check) opsx_archive_check "$@"; exit $? ;;
  loop)          opsx_loop "$@"; exit $? ;;
  worktree)      opsx_worktree "$@"; exit $? ;;
  clean)         opsx_clean "$@"; exit $? ;;
  -h|--help|help) opsx_usage; exit 0 ;;
  "") echo "opsx: missing subcommand" >&2; opsx_usage; exit 2 ;;
  *) echo "opsx: unknown subcommand: $sub" >&2; opsx_usage; exit 2 ;;
esac
