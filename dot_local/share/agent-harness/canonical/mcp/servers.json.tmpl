{
  "mcpServers": {
    "furi": {
      "command": "furi",
      "args": [
        "connect"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp"
      ]
    },
    "mcp-memory": {
      "type": "http",
      "url": "https://mcp-memory.internal.cartwmic.com/mcp",
      "headers": {
        "Authorization": "Bearer ${MCP_MEMORY_API_KEY}"
      }
    }
  }
}
