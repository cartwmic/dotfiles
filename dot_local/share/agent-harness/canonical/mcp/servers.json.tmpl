{
  "mcpServers": {
    "furi": {
      "command": "furi",
      "args": [
        "connect"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp"
      ]
    },
    "hindsight": {
      "type": "http",
      "url": "https://hindsight-api.internal.cartwmic.com/mcp/{{ if eq .profile "axon-work-computer" }}work{{ else }}cartwmic{{ end }}/",
      "lifecycle": "keep-alive"
    }{{ if eq .profile "axon-work-computer" }},
    "jira": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "${JIRA_MCP_URL}"
      ]
    },
    "slack": {
      "type": "http",
      "url": "${SLACK_MCP_URL}"
    },
    "google-workspace": {
      "type": "http",
      "url": "${GOOGLE_WORKSPACE_MCP_URL}"
    },
    "glean": {
      "type": "http",
      "url": "${GLEAN_MCP_URL}"
    },
    "pagerduty": {
      "type": "http",
      "url": "${PAGERDUTY_MCP_URL}"
    },
    "zoom": {
      "type": "http",
      "url": "${ZOOM_MCP_URL}"
    },
    "incident-io": {
      "type": "http",
      "url": "${INCIDENT_IO_MCP_URL}"
    },
    "devhub": {
      "type": "http",
      "url": "${DEVHUB_MCP_URL}"
    }{{ end }}
  }
}
