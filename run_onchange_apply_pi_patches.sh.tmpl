#!/bin/sh
#
# chezmoi run_onchange — re-applies pi-coding-agent runtime patches when
# any of (a) the patch payload, (b) the apply script, or (c) the installed
# pi-coding-agent version changes.
#
# The hash comments below give chezmoi a content-derived trigger; do not
# edit them by hand — chezmoi templating regenerates them on apply.
#
# patch.mjs (anthropic-idle-watchdog):      {{ include "dot_local/share/pi-patches/anthropic-idle-watchdog/patch.mjs" | sha256sum }}
# patch.mjs (hide-nonbridge-claude-models): {{ include "dot_local/share/pi-patches/hide-nonbridge-claude-models/patch.mjs" | sha256sum }}
# apply script:                             {{ include "dot_local/user_scripts/executable_apply_pi_patches.sh" | sha256sum }}
# pi-coding-agent installed version:        {{ output "node" "-e" "const f=require('fs'),p=require('path'),c=require('child_process');try{const r=c.execFileSync('npm',['root','-g'],{encoding:'utf8'}).trim();console.log(JSON.parse(f.readFileSync(p.join(r,'@earendil-works/pi-coding-agent/package.json'),'utf8')).version)}catch(e){console.log('not-installed')}" | trim }}
# pi-ai installed version:                  {{ output "node" "-e" "const f=require('fs'),p=require('path'),c=require('child_process');try{const r=c.execFileSync('npm',['root','-g'],{encoding:'utf8'}).trim();console.log(JSON.parse(f.readFileSync(p.join(r,'@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-ai/package.json'),'utf8')).version)}catch(e){console.log('not-installed')}" | trim }}

set -eu

SCRIPT="$HOME/.local/user_scripts/apply_pi_patches.sh"

if [ ! -x "$SCRIPT" ]; then
  echo "[apply_pi_patches] INFO: pi-patches apply script not found at $SCRIPT, skipping"
  exit 0
fi

# Thread the active chezmoi profile to the patch loop. Profile-gated patches
# (e.g. hide-nonbridge-claude-models) read PI_CHEZMOI_PROFILE and only apply on
# the matching profile; un-gated patches ignore it.
export PI_CHEZMOI_PROFILE="{{ .profile }}"

exec "$SCRIPT"
